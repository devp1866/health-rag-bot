
#  OLLAMA — never push model weights or Ollama internals
.ollama/
.ollama
ollama/
*.gguf                        # raw model weight files
*.ggml                        # older GGML format weights
*.bin                         # generic binary model weights
id_ed25519                    # Ollama private key (auto-generated)
id_ed25519.pub                # Ollama public key


#  PROJECT DATA — PDFs, vector DB, BM25 index, parent docs
#  These are large and user-specific — never push
data/documents/               # source health PDFs
data/vectordb/                # ChromaDB persisted vector store
data/bm25_cache.pkl           # BM25 serialized index
data/parent_docs.pkl          # parent document store
data/*.pkl                    # any other pickle files
data/*.db                     # any SQLite/DB files
data/*.faiss                  # FAISS index files
data/*.index                  # generic index files

# Keep the data/ folder structure in git but not the files
!data/.gitkeep
!data/documents/.gitkeep


#  PYTHON
# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/
*.whl

